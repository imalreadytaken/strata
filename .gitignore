# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Coverage
coverage/

# Runtime data (the Strata user-data dir is at ~/.strata, never inside the repo)
*.db
*.db-wal
*.db-shm

# Logs
*.log
logs/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.local
.env.*.local

# Claude Code: ignore local state but keep the OpenSpec slash commands / skills
# generated by `openspec init --tools claude` (they belong to the repo).
.claude/*
!.claude/commands/
!.claude/skills/

# OpenSpec scratch
openspec/changes/*/.work/
