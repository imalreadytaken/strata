# Dependencies
node_modules/

# Build output
# (Strata's tsc outDir is ./dist per tsconfig.json. We deliberately do NOT
# blanket-ignore `build/` here — Strata's Build Bridge source lives at
# src/build/ and gitignore patterns without a leading `/` match anywhere
# in the tree. Earlier `build/` line silently excluded ~5000 lines of
# Build Bridge code from every commit — see `fix(git): recover src/build`.)
/dist/
*.tsbuildinfo

# Coverage
coverage/

# Runtime data (the Strata user-data dir is at ~/.strata, never inside the repo)
*.db
*.db-wal
*.db-shm

# Logs
*.log
logs/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.local
.env.*.local

# Claude Code: ignore local state but keep the OpenSpec slash commands / skills
# generated by `openspec init --tools claude` (they belong to the repo).
.claude/*
!.claude/commands/
!.claude/skills/

# OpenSpec scratch
openspec/changes/*/.work/
